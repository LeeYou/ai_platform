# =============================================================================
# deploy/.env.example
# Docker Compose 环境变量配置示例
#
# 使用方法：
#   cp deploy/.env.example deploy/.env
#
# 注意：deploy/.env 已经在项目中创建，此文件仅供参考
# =============================================================================

# Docker BuildKit 优化（启用构建缓存优化）
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1
