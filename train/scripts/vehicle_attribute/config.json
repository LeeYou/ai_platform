{
  "capability": "vehicle_attribute",
  "capability_name_cn": "车辆属性识别（颜色/车型/品牌）",
  "model_arch": "ResNet50 multi-head",
  "input_size": [
    224,
    224
  ],
  "batch_size": 32,
  "epochs": 80,
  "lr0": 0.01,
  "lrf": 0.001,
  "momentum": 0.937,
  "weight_decay": 0.0005,
  "warmup_epochs": 3,
  "augment": true,
  "workers": 4,
  "device": "auto",
  "amp": true,
  "patience": 20,
  "val_split": 0.1,
  "preprocessing": {
    "mean": [
      0.485,
      0.456,
      0.406
    ],
    "std": [
      0.229,
      0.224,
      0.225
    ],
    "normalize": true,
    "color_format": "RGB"
  }
}